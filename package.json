{
  "name": "faith-counseling",
  "version": "1.4.0",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node ops/start-all.mjs",
    "start:all": "node ops/start-all.mjs",
    "start:web": "pnpm --filter @faith/web start",
    "start:api": "pnpm --filter @faith/api start",
    "start:worker": "pnpm --filter @faith/worker start",
    "reset:language": "node ops/reset-language-settings.mjs && node ops/push-clean-messages.mjs",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:step12": "node ops/step12-validate.mjs",
    "test:security": "node ops/security-regression.mjs",
    "test:e2e": "playwright test tests/e2e/high-value-journeys.spec.mjs",
    "test:launch-readiness": "playwright test tests/e2e/launch-readiness.spec.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "axe-core": "^4.11.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["argon2"]
  }
}

{
  "name": "faith-counseling",
  "version": "6.1.0",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node --env-file=.env ops/start-all.mjs",
    "start:all": "node --env-file=.env ops/start-all.mjs",
    "start:web": "pnpm --filter @faith/web start",
    "start:api": "pnpm --filter @faith/api start",
    "start:api:standalone": "pnpm --filter @faith/api start:standalone",
    "start:worker": "pnpm --filter @faith/worker start",
    "reset:language": "node ops/reset-language-settings.mjs && node ops/push-clean-messages.mjs",
    "i18n:status": "node --env-file=.env ops/i18n-status.mjs",
    "i18n:translate": "node --env-file=.env ops/translate-locale.mjs",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:step12": "node ops/step12-validate.mjs",
    "test:security": "node ops/security-regression.mjs",
    "security:appsec": "node ops/appsec-scan.mjs",
    "security:db": "node ops/db-security-scan.mjs",
    "security:nightly": "node ops/nightly-security-runner.mjs",
    "security:nightly:dry": "node ops/nightly-security-runner.mjs --dry-run",
    "test:e2e": "playwright test tests/e2e/high-value-journeys.spec.mjs",
    "test:launch-readiness": "playwright test tests/e2e/launch-readiness.spec.mjs",
    "demo:apply": "node --env-file=.env ops/demo-dataset/apply.mjs",
    "demo:verify": "node --env-file=.env ops/demo-dataset/verify.mjs",
    "demo:finalize": "node --env-file=.env ops/demo-dataset/finalize.mjs",
    "demo:sql:generate": "node --env-file=.env ops/demo-dataset/generate-sql.mjs",
    "demo:sql:apply": "node --env-file=.env ops/demo-dataset/apply-sql.mjs",
    "demo:sql:refresh": "pnpm demo:sql:generate && pnpm demo:sql:apply",
    "agent:translation:build": "docker compose --profile agent build translation-guardian",
    "agent:translation:run": "docker compose --profile agent up translation-guardian",
    "agent:translation:run:detached": "docker compose --profile agent up -d translation-guardian",
    "agent:translation:logs": "docker compose --profile agent logs -f translation-guardian",
    "agent:translation:down": "docker compose --profile agent stop translation-guardian"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "axe-core": "^4.11.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["argon2"],
    "overrides": {
      "tar": ">=7.5.11",
      "protobufjs": ">=7.5.5",
      "brace-expansion": ">=1.1.13"
    }
  }
}
